                {/* Deskripsi */}
                <div className="mb-3 flex-shrink-0 rounded-xl px-3 py-2"
                  style={{ background: 'rgba(255,253,247,0.92)' }}>
                  <p className="text-[11px] leading-relaxed" style={{ color: '#1c1917' }}>
                    Tari Kecak adalah pertunjukan seni tari khas Bali yang menggabungkan drama dan tari. Pertunjukan ini menampilkan puluhan penari pria yang duduk melingkar sambil menyerukan "cak" secara berirama, menceritakan kisah Ramayana...
                  </p>
                  <button className="mt-1 flex items-center gap-1 text-[10px] font-bold" style={{ color:'#b45309' }}>
                    ▼ Baca selengkapnya
                  </button>
                </div>

                {/* Kuis */}
                <div className="mt-auto space-y-2">
                  <div className="rounded-xl p-3" style={{ background: 'rgba(255,253,247,0.95)' }}>
                    <div className="flex items-center gap-2 mb-2">
                      <div className="flex-1 h-px" style={{ background:'linear-gradient(90deg, transparent, #d97706, transparent)' }}/>
                      <div className="flex items-center gap-1 px-2 py-0.5 rounded-full border border-amber-300/50"
                        style={{ background:'rgba(217,119,6,0.12)' }}>
                        <span className="text-amber-600 text-[8px]">✦</span>
                        <p className="text-[8px] font-black uppercase tracking-[0.15em] text-amber-700">Kuis</p>
                        <span className="text-amber-600 text-[8px]">✦</span>
                      </div>
                      <div className="flex-1 h-px" style={{ background:'linear-gradient(90deg, #d97706, transparent)' }}/>
                    </div>
                    <p className="text-xs font-bold text-slate-900 leading-snug mb-2">
                      Di provinsi mana Tari Kecak berasal?
                    </p>
                    <div className="space-y-1.5">
                      {[['A','Jawa Tengah'],['B','Bali'],['C','Nusa Tenggara Barat']].map(([letter,text])=>(
                        <button key={letter} className="w-full flex items-center gap-2 px-3 py-2 rounded-xl text-left text-[11px] font-medium cursor-pointer"
                          style={{ background:'#ffffff', border:'1.5px solid rgba(180,83,9,0.25)', color:'#1c1917' }}>
                          <span className="flex-shrink-0 w-4 h-4 rounded-full flex items-center justify-center text-[8px] font-black"
                            style={{ background:'rgba(180,83,9,0.12)', color:'#92400e' }}>
                            {letter}
