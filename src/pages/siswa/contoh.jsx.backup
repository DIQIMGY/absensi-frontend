                  <div className="flex-1 h-px opacity-20" style={{ background:'#10b981' }}/>
                </div>
                <div className="flex gap-2 overflow-hidden">
                  {['bg-emerald-200','bg-teal-200','bg-cyan-200','bg-green-200'].map((c,i)=>(
                    <div key={i} className={`flex-shrink-0 ${c} rounded-xl`} style={{width:160,height:90}}/>
                  ))}
                </div>
              </div>
              {/* Strip 2 placeholder */}
              <div>
                <div className="flex items-center gap-2.5 mb-2.5">
                  <div className="w-5 h-5 rounded-lg flex items-center justify-center flex-shrink-0" style={{ background:'#0891b2' }}>
                    <span className="text-white text-[8px]">🌊</span>
                  </div>
                  <span className="text-[10px] font-black uppercase tracking-[0.18em]" style={{ color:'#0891b2' }}>Pesona Nusantara</span>
