              </div>
              <div className="flex flex-wrap gap-2">
                {[{color:'bg-emerald-500',label:'Hadir'},{color:'bg-amber-500',label:'Terlambat'},{color:'bg-violet-500',label:'Izin'},{color:'bg-rose-500',label:'Alpha'}].map(s=>(
                  <div key={s.label} className="flex items-center gap-1.5">
                    <div className={`w-2 h-2 rounded-sm ${s.color}`}/>
                    <span className="text-[10px] text-slate-400">{s.label}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>

          {/* ── BudayaIndonesia ── */}
          <div className="relative overflow-hidden rounded-2xl border border-amber-200/60 dark:border-amber-900/40"
            style={{ background: '#fffbeb', minHeight: 260 }}>
            <div className="absolute inset-0 hidden dark:block" style={{ background: '#0f0a00' }}/>
            {/* Batik pattern overlay */}
            <div className="absolute inset-0 pointer-events-none opacity-20"
              style={{backgroundImage:'repeating-linear-gradient(45deg,#d97706 0,#d97706 1px,transparent 0,transparent 50%)',backgroundSize:'12px 12px'}}/>
            <div className="absolute inset-x-0 top-0 h-0.5"
              style={{ background: 'linear-gradient(90deg, #92400e, #b45309, #d97706, #b45309, #92400e)' }}/>
            <div className="relative z-10 flex flex-col sm:flex-row" style={{ minHeight:258 }}>

              {/* Kiri: foto placeholder */}
              <div className="relative overflow-hidden bg-slate-800 sm:w-[42%] flex-shrink-0 rounded-l-2xl sm:rounded-l-2xl rounded-t-2xl sm:rounded-t-none flex items-center justify-center"
                style={{ minHeight:220 }}>
                <div className="absolute inset-0 bg-gradient-to-br from-amber-900/60 to-slate-900"/>
                <div className="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent pointer-events-none"/>
                {/* Badge */}
                <div className="absolute top-3 left-3 flex items-center gap-1.5 px-2.5 py-1 rounded-full border border-amber-400/30"
                  style={{ background: 'rgba(146,64,14,0.7)' }}>
                  <span className="text-amber-300 text-[8px]">✦</span>
                  <span className="text-[8px] font-bold uppercase tracking-[0.15em] text-amber-100">Nusantara</span>
                  <span className="text-amber-300 text-[8px]">✦</span>
                </div>
                {/* Dots */}
                <div className="absolute top-3 right-3 flex items-center gap-1">
                  {[0,1,2].map(i=>(
                    <div key={i} className="rounded-full transition-all duration-300"
                      style={{width:i===0?14:4,height:4,background:i===0?'#fbbf24':'rgba(255,255,255,0.3)'}}/>
                  ))}
                </div>
                <div className="relative z-10 flex flex-col items-center gap-2">
                  <div className="w-16 h-16 rounded-full bg-amber-700/40 flex items-center justify-center">
                    <span className="text-3xl">🎭</span>
                  </div>
                  <p className="text-white/60 text-xs">Tari Kecak Bali</p>
                </div>
                <div className="absolute bottom-0 inset-x-0 p-3.5">
                  <p className="text-white font-black text-sm leading-tight"
                    style={{ textShadow:'0 1px 8px rgba(0,0,0,0.9)' }}>Tari Kecak Bali</p>
                  <p className="text-white/40 text-[9px]">1 / 3</p>
                </div>
              </div>

              {/* Kanan: Info + Kuis */}
              <div className="relative flex flex-col p-4 sm:p-5 flex-1 min-w-0">
                <div className="absolute inset-0 rounded-r-2xl pointer-events-none"
                  style={{ background: 'rgba(255,251,235,0.15)' }}/>

                {/* Header */}
                <div className="flex items-start gap-2 mb-3 rounded-xl px-3 py-2"
                  style={{ background: 'rgba(255,253,247,0.85)' }}>
                  <div className="flex-shrink-0 mt-0.5">
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                      <circle cx="9" cy="9" r="3" fill="#b45309" opacity="0.8"/>
                      <circle cx="9" cy="9" r="1.5" fill="#fbbf24"/>
                    </svg>
                  </div>
                  <div className="min-w-0">
                    <p className="text-[9px] font-black uppercase tracking-[0.18em] mb-0.5" style={{ color:'#92400e' }}>
                      Kenali Nusantara
                    </p>
                  </div>
