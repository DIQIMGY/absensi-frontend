              <div className="flex border-b border-slate-100 dark:border-slate-700/50">
                {[{label:'Terbaik',color:'text-amber-600',border:'border-amber-500',active:true},
                  {label:'Terlambat',color:'text-orange-500',border:'border-orange-500',active:false},
                  {label:'Alpha',color:'text-rose-500',border:'border-rose-500',active:false}].map((tab,i)=>(
                  <button key={i} className={`flex-1 flex items-center justify-center gap-1 py-2 text-[11px] font-semibold transition-all border-b-2 ${tab.active?`${tab.color} ${tab.border} bg-slate-50/80 dark:bg-slate-800/50`:'text-slate-400 border-transparent'}`}>
                    {tab.label}
                  </button>
                ))}
              </div>
              <div className="p-3 space-y-1.5">
                {[
                  {rank:'🥇',nama:'Siti Rahayu',kelas:'XII RPL 1',val:48,isMe:false},
                  {rank:'🥈',nama:'Budi Santoso',kelas:'XII RPL 1',val:47,isMe:false},
                  {rank:'🥉',nama:'Ahmad Fauzi',kelas:'XII RPL 1',val:45,isMe:true},
                  {rank:4,  nama:'Dewi Lestari',kelas:'XII RPL 1',val:44,isMe:false},
                  {rank:5,  nama:'Rizky Pratama',kelas:'XII RPL 1',val:43,isMe:false},
                ].map((s,i)=>(
                  <div key={i} className={`relative flex items-center gap-2 px-3 py-2 rounded-xl overflow-hidden border transition-all ${
                    s.isMe?'bg-violet-100 dark:bg-violet-900/30 border-violet-200 dark:border-violet-700/50 ring-1 ring-violet-300 dark:ring-violet-700/50'
                    :i===0?'bg-amber-100 dark:bg-amber-900/30 border-amber-200 dark:border-amber-700/40'
                    :'bg-slate-50 dark:bg-slate-800/60 border-slate-200 dark:border-slate-700/50'}`}>
                    <div className="absolute inset-y-0 left-0 rounded-xl pointer-events-none opacity-10"
                      style={{width:`${Math.round((s.val/48)*100)}%`,backgroundColor:'#f59e0b'}}/>
                    <span className="relative z-10 text-sm w-5 text-center flex-shrink-0 font-black">
                      {typeof s.rank==='string'?s.rank:<span className="text-xs text-slate-400">{s.rank}</span>}
                    </span>
                    <div className="relative z-10 w-7 h-7 rounded-full bg-gradient-to-br from-violet-400 to-indigo-500 flex items-center justify-center text-white text-xs font-bold flex-shrink-0">
                      {s.nama.charAt(0)}
                    </div>
                    <div className="relative z-10 flex-1 min-w-0">
                      <div className="flex items-center gap-1">
                        <p className="text-xs font-semibold text-slate-800 dark:text-slate-200 truncate">{s.nama}</p>
                        {s.isMe && <span className="text-[8px] font-black px-1 py-0.5 rounded-full bg-violet-100 dark:bg-violet-900/40 text-violet-600 dark:text-violet-300 flex-shrink-0">Kamu</span>}
                      </div>
                      <p className="text-[9px] text-slate-400 truncate">{s.kelas}</p>
                    </div>
                    <span className={`relative z-10 px-1.5 py-0.5 rounded-full text-[10px] font-bold tabular-nums flex-shrink-0 ${
                      s.isMe?'bg-violet-100 dark:bg-violet-900/40 text-violet-700 dark:text-violet-300'
                      :i===0?'bg-amber-100 dark:bg-amber-900/40 text-amber-700 dark:text-amber-300'
                      :'bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300'}`}>
                      {s.val}x
                    </span>
                  </div>
                ))}
              </div>
              {/* Ranking Sekolah */}
              <div className="mx-3 mb-3 pt-3 border-t border-slate-100 dark:border-slate-800">
                <p className="text-[9px] text-slate-400 font-semibold uppercase tracking-wide mb-2">Ranking Sekolah</p>
                <div className="grid grid-cols-3 gap-1.5">
                  {[{label:'Hadir',pos:12,color:'text-amber-600',bg:'bg-amber-100',border:'border-amber-100'},
                    {label:'Terlambat',pos:45,color:'text-orange-600',bg:'bg-orange-50',border:'border-orange-100'},
                    {label:'Alpha',pos:null,color:'text-rose-600',bg:'bg-rose-50',border:'border-rose-100'}].map((item,i)=>(
                    <div key={i} className={`rounded-xl px-2 py-1.5 ${item.bg} border ${item.border} text-center`}>
                      <p className="text-[8px] text-slate-400 mb-0.5">{item.label}</p>
                      <p className={`text-sm font-black ${item.color}`}>{item.pos?`#${item.pos}`:'—'}</p>
                    </div>
                  ))}
                </div>
              </div>
            </div>

            {/* Riwayat Terakhir */}
            <div className="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700/60 rounded-2xl overflow-hidden shadow-sm">
              <div className="flex items-center justify-between px-4 py-3 border-b border-slate-100 dark:border-slate-700/50">
                <div className="flex items-center gap-2">
                  <div className="w-7 h-7 rounded-lg bg-teal-100 dark:bg-teal-900/50 flex items-center justify-center">
                    <span className="text-teal-600 text-xs">🕐</span>
                  </div>
                  <div>
                    <p className="text-sm font-bold text-slate-800 dark:text-slate-100">Riwayat Terakhir</p>
                    <p className="text-[10px] text-slate-400">7 hari terakhir</p>
                  </div>
                </div>
                <span className="text-[11px] text-slate-400 flex items-center gap-0.5">Semua ›</span>
              </div>
              <div>
                {[
                  {tanggal:'Senin, 6 Apr 2026',  jam:'07:15', status:'hadir',     dot:'bg-emerald-500', pill:'bg-emerald-100 dark:bg-emerald-900/50 text-emerald-700 dark:text-emerald-300 border-emerald-200 dark:border-emerald-800/40'},
                  {tanggal:'Jumat, 4 Apr 2026',  jam:'07:20', status:'hadir',     dot:'bg-emerald-500', pill:'bg-emerald-100 dark:bg-emerald-900/50 text-emerald-700 dark:text-emerald-300 border-emerald-200 dark:border-emerald-800/40'},
                  {tanggal:'Kamis, 3 Apr 2026',  jam:'07:45', status:'terlambat', dot:'bg-amber-500',   pill:'bg-amber-50 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300 border-amber-200 dark:border-amber-800/40', menit:15},
                  {tanggal:'Rabu, 2 Apr 2026',   jam:'07:10', status:'hadir',     dot:'bg-emerald-500', pill:'bg-emerald-100 dark:bg-emerald-900/50 text-emerald-700 dark:text-emerald-300 border-emerald-200 dark:border-emerald-800/40'},
                  {tanggal:'Selasa, 1 Apr 2026', jam:'07:18', status:'hadir',     dot:'bg-emerald-500', pill:'bg-emerald-100 dark:bg-emerald-900/50 text-emerald-700 dark:text-emerald-300 border-emerald-200 dark:border-emerald-800/40'},
                  {tanggal:'Senin, 31 Mar 2026', jam:'07:22', status:'hadir',     dot:'bg-emerald-500', pill:'bg-emerald-100 dark:bg-emerald-900/50 text-emerald-700 dark:text-emerald-300 border-emerald-200 dark:border-emerald-800/40'},
                  {tanggal:'Jumat, 28 Mar 2026', jam:'—',     status:'izin',      dot:'bg-violet-500',  pill:'bg-violet-100 dark:bg-violet-900/50 text-violet-700 dark:text-violet-300 border-violet-200 dark:border-violet-800/40'},
                ].map((r,i,arr)=>(
                  <div key={i} className="flex items-center gap-3 px-4 py-2.5 hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors"
                    style={{borderBottom:i<arr.length-1?'1px solid rgba(148,163,184,0.08)':'none'}}>
                    <div className={`w-1.5 h-1.5 rounded-full flex-shrink-0 ${r.dot}`}/>
                    <div className="flex-1 min-w-0">
                      <p className="text-xs font-semibold text-slate-700 dark:text-slate-200 truncate">{r.tanggal}</p>
                      {r.jam!=='—' && <p className="text-[10px] text-slate-400 font-mono">{r.jam}</p>}
                    </div>
                    {r.menit && <span className="text-[9px] text-amber-500 font-semibold flex-shrink-0">+{r.menit}m</span>}
                    <span className={`flex items-center gap-1 text-[10px] font-semibold px-2 py-0.5 rounded-full capitalize flex-shrink-0 border ${r.pill}`}>
                      {r.status}
                    </span>
                  </div>
                ))}
              </div>
            </div>
          </div>

          {/* ── ROW 7: Riwayat Izin ── */}
          <div className="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700/60 rounded-2xl overflow-hidden shadow-sm">
            <div className="flex items-center justify-between px-4 py-3 border-b border-slate-100 dark:border-slate-700/50">
              <div className="flex items-center gap-2">
                <div className="w-7 h-7 rounded-lg bg-violet-100 dark:bg-violet-900/50 flex items-center justify-center">
                  <span className="text-violet-500 text-xs">📄</span>
                </div>
                <div>
                  <p className="text-sm font-bold text-slate-800 dark:text-slate-100">Riwayat Izin</p>
                  <p className="text-[10px] text-slate-400">Pengajuan terakhir</p>
                </div>
              </div>
              <span className="text-[11px] text-slate-400 flex items-center gap-0.5">Semua ›</span>
            </div>
            <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 divide-y sm:divide-y-0 sm:divide-x divide-slate-50 dark:divide-slate-800">
              {[
                {jenis:'Sakit',tanggal:'28 Mar 2026',status:'approved',statusLabel:'Disetujui',icon:'🤒',iconBg:'bg-rose-50 dark:bg-rose-900/20',iconColor:'text-rose-500',statusCls:'bg-emerald-50 dark:bg-emerald-900/20 text-emerald-700 dark:text-emerald-300 border-emerald-100 dark:border-emerald-800/40'},
                {jenis:'Izin Keluarga',tanggal:'15 Mar 2026',status:'approved',statusLabel:'Disetujui',icon:'👨‍👩‍👧',iconBg:'bg-violet-50 dark:bg-violet-900/20',iconColor:'text-violet-500',statusCls:'bg-emerald-50 dark:bg-emerald-900/20 text-emerald-700 dark:text-emerald-300 border-emerald-100 dark:border-emerald-800/40'},
                {jenis:'Izin Lainnya',tanggal:'2 Mar 2026',status:'pending',statusLabel:'Menunggu',icon:'📋',iconBg:'bg-violet-50 dark:bg-violet-900/20',iconColor:'text-violet-500',statusCls:'bg-amber-100 dark:bg-amber-900/40 text-amber-700 dark:text-amber-300 border-amber-100 dark:border-amber-800/40'},
              ].map((izin,i)=>(
                <div key={i} className="flex items-center gap-3 px-4 py-3 hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
                  <div className={`w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0 ${izin.iconBg}`}>
                    <span className="text-lg">{izin.icon}</span>
                  </div>
                  <div className="flex-1 min-w-0">
                    <p className="text-xs font-semibold text-slate-700 dark:text-slate-200 truncate">{izin.jenis}</p>
                    <p className="text-[10px] text-slate-400 truncate">{izin.tanggal}</p>
                  </div>
                  <span className={`text-[9px] font-bold px-2 py-0.5 rounded-full flex-shrink-0 border ${izin.statusCls}`}>
                    {izin.statusLabel}
                  </span>
                </div>
              ))}
            </div>
          </div>

          {/* ── ROW 8: Menu Cepat ── */}
          <div>
            <div className="flex items-center gap-2 mb-2">
              <span className="text-slate-400 text-xs">⚡</span>
              <p className="text-[10px] font-semibold text-slate-400 uppercase tracking-wider">Menu Cepat</p>
            </div>
            <div className="grid grid-cols-2 sm:grid-cols-4 gap-2.5">
              {[
                {label:'Absen QR',  icon:'📱', color:'#7c3aed', iconBg:'bg-violet-100 dark:bg-violet-900/50', border:'border-violet-100 dark:border-violet-800/40', tc:'text-violet-600 dark:text-violet-400'},
                {label:'Riwayat',   icon:'🕐', color:'#0d9488', iconBg:'bg-teal-100 dark:bg-teal-900/50',   border:'border-teal-100 dark:border-teal-800/40',   tc:'text-teal-600 dark:text-teal-400'},
                {label:'Izin',      icon:'📄', color:'#8b5cf6', iconBg:'bg-purple-50 dark:bg-purple-900/30',border:'border-purple-100 dark:border-purple-800/40',tc:'text-purple-600 dark:text-purple-400'},
                {label:'Profil',    icon:'👤', color:'#3b82f6', iconBg:'bg-blue-50 dark:bg-blue-900/30',    border:'border-blue-100 dark:border-blue-800/40',   tc:'text-blue-600 dark:text-blue-400'},
              ].map((nav,i)=>(
                <div key={nav.label}
                  className={`flex items-center gap-3 bg-white dark:bg-slate-900 ${nav.border} border rounded-xl p-3.5 hover:shadow-sm transition-all group cursor-pointer`}>
                  <div className={`w-9 h-9 rounded-xl flex items-center justify-center ${nav.iconBg} group-hover:scale-105 transition-transform`}>
                    <span className="text-lg">{nav.icon}</span>
                  </div>
                  <span className={`font-semibold text-sm ${nav.tc}`}>{nav.label}</span>
                  <span className="ml-auto text-slate-300 dark:text-slate-600 text-xs">›</span>
                </div>
              ))}
            </div>
          </div>

        </div>
      </div>
    </>
  )
}
