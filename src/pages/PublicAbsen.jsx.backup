import { useState, useEffect } from 'react'
import { motion, AnimatePresence } from 'framer-motion'
import { 
  User, 
  Hash, 
  QrCode, 
  Camera, 
  CheckCircle, 
  AlertCircle, 
  X,
  ChevronRight,
  Clock,
  Calendar,
  Loader,
  School,
  ScanLine,
  Fingerprint,
  ArrowRight,
  Info,
  Sparkles,
  Shield
} from 'lucide-react'
import { publicApi } from '../services/publicApi'
import QrScanner from '../components/QrScanner'
import { showWarning, showSuccess, showError } from '../components/ConfirmDialog'
import { Link } from 'react-router-dom'
import { playSuccessSound, playErrorSound, playWarningSound, playScanSound, playLateSound } from '../utils/soundNotification'
import { usePengaturanStore } from '../stores/pengaturanStore'

export default function PublicAbsen() {
  const [activeTab, setActiveTab] = useState('manual')
  const [loading, setLoading] = useState(false)
  const [showScanner, setShowScanner] = useState(false)
  const [formData, setFormData] = useState({
    nisn: '',
    nama_lengkap: ''
  })
  const [errors, setErrors] = useState({})
  const [absenResult, setAbsenResult] = useState(null)
  const [waktuSekarang, setWaktuSekarang] = useState(new Date())
  const [jamMasuk, setJamMasuk] = useState('07:15')
  const [isScrolled, setIsScrolled] = useState(false)
  
  const { pengaturan } = usePengaturanStore()

  const getKeterangan = () => {
    try {
      return `public-absen; ua=${navigator.userAgent}`
    } catch {
      return 'public-absen'
    }
  }

  useEffect(() => {
    const timer = setInterval(() => {
      setWaktuSekarang(new Date())
    }, 1000)
    return () => clearInterval(timer)
  }, [])

  useEffect(() => {
    const handleScroll = () => {
      setIsScrolled(window.scrollY > 20)
    }
    window.addEventListener('scroll', handleScroll, { passive: true })
    return () => window.removeEventListener('scroll', handleScroll)
  }, [])

  useEffect(() => {
    fetchPengaturan()
  }, [])

  const fetchPengaturan = async () => {
    try {
      const response = await publicApi.getPengaturan()
      if (response.data.data?.jam_masuk) {
        setJamMasuk(response.data.data.jam_masuk.substring(0, 5))
      }
    } catch (error) {
      console.error('Gagal ambil pengaturan:', error)
      if (pengaturan.jam_masuk) {
        setJamMasuk(pengaturan.jam_masuk)
      }
    }
  }

  const formatWaktu = (date) => {
    return date.toLocaleTimeString('id-ID', { 
      hour: '2-digit', 
      minute: '2-digit', 
      second: '2-digit' 
    })
  }

  const formatTanggal = (date) => {
    return date.toLocaleDateString('id-ID', { 
      weekday: 'long', 
      year: 'numeric', 
      month: 'long', 
      day: 'numeric' 
    })
  }

  const handleInputChange = (e) => {
    const { name, value } = e.target
    setFormData(prev => ({ ...prev, [name]: value }))
    if (errors[name]) {
      setErrors(prev => ({ ...prev, [name]: '' }))
    }
  }

  const validateForm = () => {
    const newErrors = {}
    if (!formData.nisn.trim()) {
      newErrors.nisn = 'NISN wajib diisi'
    } else if (formData.nisn.length < 10) {
      newErrors.nisn = 'NISN minimal 10 karakter'
    }
    if (!formData.nama_lengkap.trim()) {
      newErrors.nama_lengkap = 'Nama lengkap wajib diisi'
    }
    setErrors(newErrors)
    return Object.keys(newErrors).length === 0
  }

  const debugAbsensi = async (siswaId) => {
    try {
      const response = await publicApi.debugAbsensi({ siswa_id: siswaId })
      console.log('Debug Absensi:', response.data)
      alert(`Debug Info:\nSiswa: ${response.data.data.siswa.nama}\nHas Attendance Today: ${response.data.data.has_attendance_today}\nToday: ${response.data.data.today}\nTimezone: ${response.data.data.timezone}`)
    } catch (error) {
      console.error('Debug error:', error)
    }
  }

  const handleManualAbsen = async (e) => {
    e.preventDefault()
    
    if (!validateForm()) return

    setLoading(true)
    setAbsenResult(null)

    try {
      const response = await publicApi.absenManual({
        nisn: formData.nisn,
        nama_lengkap: formData.nama_lengkap,
        keterangan: getKeterangan()
      })
      const result = response.data.data
      
      setAbsenResult({
        success: true,
        data: result,
        message: response.data.message
      })

      setFormData({ nisn: '', nama_lengkap: '' })

      if (result.is_terlambat) {
        playLateSound()
        await showWarning(
          'Perhatian! Anda Terlambat',
          `Anda terlambat ${result.menit_terlambat} menit dari jam masuk (${jamMasuk})`
        )
      } else {
        playSuccessSound()
        showSuccess('Absensi Berhasil', 'Selamat, Anda telah berhasil absen tepat waktu')
      }

    } catch (error) {
      const response = error.response?.data
      
      setAbsenResult({
        success: false,
        message: response?.message || 'Terjadi kesalahan'
      })

      if (response?.errors) {
        setErrors(response.errors)
      }

      if (response?.message?.includes('sudah melakukan absensi')) {
        playWarningSound()
        await showWarning(
          'Sudah Absen Hari Ini',
          'Anda sudah melakukan absensi hari ini. Tidak perlu absen lagi.'
        )
        return
      }

      playErrorSound()

      if (response?.message?.includes('belum terdaftar') || response?.errors?.registrasi) {
        showError(
          'Belum Registrasi',
          'Data Anda ditemukan di sekolah, tetapi belum memiliki akun. Silakan registrasi terlebih dahulu.'
        )
      } else if (response?.message?.includes('tidak ditemukan')) {
        showError(
          'Data Tidak Ditemukan',
          'NISN tidak terdaftar di sistem. Hubungi admin jika ini kesalahan.'
        )
      } else {
        showError('Absensi Gagal', response?.message || 'Terjadi kesalahan')
      }
    } finally {
      setLoading(false)
    }
  }

  const handleQrScan = async (qrCode) => {
    setLoading(true)
    setShowScanner(false)
    playScanSound()

    try {
      const response = await publicApi.absenQr({ qr_code: qrCode, keterangan: getKeterangan() })
      const result = response.data.data
      
      setAbsenResult({
        success: true,
        data: result,
        message: response.data.message
      })

      if (result.is_terlambat) {
        playLateSound()
        await showWarning(
          'Perhatian! Anda Terlambat',
          `Anda terlambat ${result.menit_terlambat} menit dari jam masuk (${jamMasuk})`
        )
      } else {
        playSuccessSound()
        showSuccess('Absensi Berhasil', 'Selamat, Anda telah berhasil absen tepat waktu')
      }

    } catch (error) {
      const response = error.response?.data
      
      setAbsenResult({
        success: false,
        message: response?.message || 'Terjadi kesalahan'
      })

      if (response?.message?.includes('sudah melakukan absensi')) {
        playWarningSound()
        await showWarning(
          'Sudah Absen Hari Ini',
          'Anda sudah melakukan absensi hari ini. Tidak perlu absen lagi.'
        )
        return
      }

      playErrorSound()

      if (response?.message?.includes('belum terdaftar')) {
        showError(
          'Belum Registrasi',
          'QR Code valid, tetapi Anda belum memiliki akun. Silakan registrasi terlebih dahulu.'
        )
      } else if (response?.message?.includes('tidak valid')) {
        showError(
          'QR Code Tidak Valid',
          'QR Code tidak dikenali. Pastikan menggunakan QR Code dari sistem.'
        )
      } else {
        showError('Absensi Gagal', response?.message || 'Terjadi kesalahan')
      }
    } finally {
      setLoading(false)
    }
  }

  const handleScanError = (error) => {
    showError('Kamera Error', error)
  }

  const resetAbsen = () => {
    setAbsenResult(null)
    setErrors({})
  }

  const containerVariants = {
    hidden: { opacity: 0 },
    visible: { 
      opacity: 1,
      transition: {
        staggerChildren: 0.08,
        delayChildren: 0.1
      }
    }
  }

  const itemVariants = {
    hidden: { opacity: 0, y: 20 },
    visible: { 
      opacity: 1, 
      y: 0,
      transition: { 
        duration: 0.5, 
        ease: [0.22, 1, 0.36, 1] 
      }
    }
  }

  return (
    <div className="min-h-screen bg-gradient-to-br from-slate-50 via-white to-slate-100 dark:from-slate-950 dark:via-slate-900 dark:to-slate-950 font-sans selection:bg-teal-100 selection:text-teal-900 dark:selection:bg-teal-900/30 dark:selection:text-teal-100 overflow-x-hidden">
      {/* Enhanced Decorative Background */}
      <div className="fixed inset-0 overflow-hidden pointer-events-none">
        <div className="absolute top-0 left-1/4 w-[600px] h-[600px] bg-teal-200/20 dark:bg-teal-900/10 rounded-full blur-[100px] animate-pulse" />
        <div className="absolute bottom-0 right-1/4 w-[500px] h-[500px] bg-blue-200/20 dark:bg-blue-900/10 rounded-full blur-[100px] animate-pulse delay-1000" />
        <div className="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-gradient-radial from-teal-100/20 to-transparent dark:from-teal-900/5 rounded-full" />
        
        {/* Grid Pattern */}
        <div className="absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px] dark:bg-[linear-gradient(to_right,#ffffff08_1px,transparent_1px),linear-gradient(to_bottom,#ffffff08_1px,transparent_1px)]" />
      </div>

      {/* Header */}
      <motion.header 
        initial={{ y: -100, opacity: 0 }}
        animate={{ y: 0, opacity: 1 }}
        transition={{ duration: 0.6, ease: [0.22, 1, 0.36, 1] }}
        className={`fixed top-0 left-0 right-0 z-50 transition-all duration-500 ${
          isScrolled 
            ? 'bg-white/80 dark:bg-slate-900/80 backdrop-blur-2xl shadow-lg shadow-slate-200/30 dark:shadow-slate-900/30 border-b border-slate-200/50 dark:border-slate-800/50' 
            : 'bg-transparent'
        }`}
      >
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div className="flex items-center justify-between h-20">
            {/* Logo & School Name */}
            <div className="flex items-center gap-4">
              <motion.div 
                whileHover={{ scale: 1.05, rotate: 5 }}
                whileTap={{ scale: 0.95 }}
                className="relative"
              >
                {pengaturan.logo_sekolah ? (
                  <img 
                    src={pengaturan.logo_sekolah} 
                    alt="Logo Sekolah" 
                    className="w-12 h-12 rounded-2xl object-contain bg-white shadow-lg shadow-slate-200/50 dark:shadow-slate-900/50 p-1.5 ring-2 ring-slate-100 dark:ring-slate-800"
                  />
                ) : (
                  <div className="w-12 h-12 rounded-2xl bg-gradient-to-br from-teal-500 via-teal-600 to-teal-700 flex items-center justify-center text-white font-bold text-xl shadow-lg shadow-teal-500/30 ring-2 ring-white dark:ring-slate-800">
                    <School size={24} />
                  </div>
                )}
                <div className="absolute -bottom-0.5 -right-0.5 w-3.5 h-3.5 bg-emerald-500 border-2 border-white dark:border-slate-900 rounded-full animate-pulse" />
              </motion.div>
              
              <div className="hidden sm:block">
                <h1 className="text-lg font-bold text-slate-900 dark:text-white tracking-tight">
                  Sistem Absensi
                </h1>
                <p className="text-sm text-slate-500 dark:text-slate-400 font-medium truncate max-w-[200px]">
                  {pengaturan.nama_sekolah || 'SMK Negeri 8 Jember'}
                </p>
              </div>
            </div>

            {/* Time Display - Desktop */}
            <div className="hidden md:flex items-center gap-3">
              <div className="flex items-center gap-2 px-4 py-2 bg-white/60 dark:bg-slate-800/60 rounded-full backdrop-blur-sm border border-slate-200/50 dark:border-slate-700/50 shadow-sm">
                <Calendar size={14} className="text-slate-400" />
                <span className="text-xs font-semibold text-slate-600 dark:text-slate-300">
                  {formatTanggal(waktuSekarang)}
                </span>
              </div>
              <div className="flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-teal-50 to-teal-100/50 dark:from-teal-900/30 dark:to-teal-800/20 rounded-full border border-teal-200/50 dark:border-teal-800/30 shadow-sm">
                <Clock size={14} className="text-teal-600 dark:text-teal-400" />
                <span className="text-xs font-mono font-bold text-teal-700 dark:text-teal-300 tracking-wider">
                  {formatWaktu(waktuSekarang)}
                </span>
              </div>
            </div>

            {/* Login Button */}
            <Link 
              to="/login" 
              className="group flex items-center gap-2 px-5 py-2.5 bg-slate-900 dark:bg-white text-white dark:text-slate-900 rounded-full text-sm font-bold transition-all duration-300 hover:shadow-xl hover:shadow-slate-900/20 dark:hover:shadow-white/20 hover:-translate-y-0.5 active:translate-y-0"
            >
              <span>Login</span>
              <ArrowRight size={16} className="transition-transform duration-300 group-hover:translate-x-1" />
            </Link>
          </div>
        </div>
      </motion.header>

      {/* Main Content */}
      <main className="relative pt-28 sm:pt-32 pb-20 px-4 sm:px-6 lg:px-8">
        <div className="max-w-4xl mx-auto">
          
          {/* Hero Section */}
          <motion.div 
            variants={containerVariants}
            initial="hidden"
            animate="visible"
            className="text-center mb-10 sm:mb-14"
          >
            <motion.div variants={itemVariants} className="inline-flex items-center gap-2 px-4 py-2 mb-6 bg-white dark:bg-slate-800 rounded-full shadow-sm border border-slate-200 dark:border-slate-700">
              <span className="relative flex h-2 w-2">
                <span className="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                <span className="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
              </span>
              <span className="text-xs font-bold text-slate-600 dark:text-slate-400 uppercase tracking-wider">
                Sistem Aktif • Jam Masuk {jamMasuk} WIB
              </span>
            </motion.div>

            <motion.h2 
              variants={itemVariants}
              className="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 dark:text-white mb-4 tracking-tight"
            >
              Absensi <span className="text-transparent bg-clip-text bg-gradient-to-r from-teal-600 via-teal-500 to-teal-400">Digital</span>
            </motion.h2>
            
            <motion.p 
              variants={itemVariants}
              className="text-base sm:text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto leading-relaxed"
            >
              Pilih metode absensi yang Anda inginkan. Pastikan data sesuai dengan database sekolah.
            </motion.p>
          </motion.div>

          {/* Attendance Card */}
          <motion.div
            initial={{ opacity: 0, y: 40, scale: 0.98 }}
            animate={{ opacity: 1, y: 0, scale: 1 }}
            transition={{ delay: 0.2, duration: 0.7, ease: [0.22, 1, 0.36, 1] }}
            className="relative"
          >
            {/* Card Container */}
            <div className="bg-white dark:bg-slate-900 rounded-3xl shadow-2xl shadow-slate-200/50 dark:shadow-slate-950/50 overflow-hidden border border-slate-200/60 dark:border-slate-800/60">
              
              {/* Custom Tabs */}
              <div className="flex relative bg-slate-50/50 dark:bg-slate-800/30">
                {/* Sliding Background for Active Tab */}
                <motion.div
                  className="absolute bottom-0 h-1 bg-gradient-to-r from-teal-500 to-teal-400"
                  initial={false}
                  animate={{
                    left: activeTab === 'manual' ? '0%' : '50%',
                    width: '50%'
                  }}
                  transition={{ type: "spring", stiffness: 400, damping: 35 }}
                />
                
                <button
                  onClick={() => {
                    setActiveTab('manual')
                    setAbsenResult(null)
                    setErrors({})
                  }}
                  className={`flex-1 relative py-6 sm:py-8 px-4 text-center transition-all duration-300 group ${
                    activeTab === 'manual'
                      ? 'bg-white dark:bg-slate-900'
                      : 'hover:bg-white/50 dark:hover:bg-slate-900/50'
                  }`}
                >
                  <motion.div 
                    animate={{ 
                      scale: activeTab === 'manual' ? 1.1 : 1,
                      rotate: activeTab === 'manual' ? 0 : 0
                    }}
                    transition={{ type: "spring", stiffness: 300, damping: 20 }}
                    className={`mx-auto w-14 h-14 sm:w-16 sm:h-16 rounded-2xl flex items-center justify-center mb-3 transition-all duration-300 ${
                      activeTab === 'manual' 
                        ? 'bg-gradient-to-br from-teal-500 to-teal-600 text-white shadow-lg shadow-teal-500/30' 
                        : 'bg-slate-100 dark:bg-slate-800 text-slate-400 group-hover:text-slate-600 dark:group-hover:text-slate-300'
                    }`}
                  >
                    <Fingerprint size={26} strokeWidth={activeTab === 'manual' ? 2.5 : 2} />
                  </motion.div>
                  <h3 className={`font-bold text-sm sm:text-base mb-1 transition-colors ${
                    activeTab === 'manual' ? 'text-slate-900 dark:text-white' : 'text-slate-500 dark:text-slate-500'
                  }`}>
                    Absen Manual
                  </h3>
                  <p className="text-[10px] sm:text-xs text-slate-400 dark:text-slate-500 font-medium">
                    NISN & Nama Lengkap
                  </p>
                </button>

                <div className="w-px bg-slate-200 dark:bg-slate-700 self-stretch my-6" />

                <button
                  onClick={() => {
                    setActiveTab('qr')
                    setAbsenResult(null)
                    setErrors({})
                  }}
                  className={`flex-1 relative py-6 sm:py-8 px-4 text-center transition-all duration-300 group ${
                    activeTab === 'qr'
                      ? 'bg-white dark:bg-slate-900'
                      : 'hover:bg-white/50 dark:hover:bg-slate-900/50'
                  }`}
                >
                  <motion.div 
                    animate={{ 
                      scale: activeTab === 'qr' ? 1.1 : 1 
                    }}
                    transition={{ type: "spring", stiffness: 300, damping: 20 }}
                    className={`mx-auto w-14 h-14 sm:w-16 sm:h-16 rounded-2xl flex items-center justify-center mb-3 transition-all duration-300 ${
                      activeTab === 'qr' 
                        ? 'bg-gradient-to-br from-teal-500 to-teal-600 text-white shadow-lg shadow-teal-500/30' 
                        : 'bg-slate-100 dark:bg-slate-800 text-slate-400 group-hover:text-slate-600 dark:group-hover:text-slate-300'
                    }`}
                  >
                    <ScanLine size={26} strokeWidth={activeTab === 'qr' ? 2.5 : 2} />
                  </motion.div>
                  <h3 className={`font-bold text-sm sm:text-base mb-1 transition-colors ${
                    activeTab === 'qr' ? 'text-slate-900 dark:text-white' : 'text-slate-500 dark:text-slate-500'
                  }`}>
                    Scan QR Code
                  </h3>
                  <p className="text-[10px] sm:text-xs text-slate-400 dark:text-slate-500 font-medium">
                    Gunakan Kamera
                  </p>
                </button>
              </div>

              {/* Content Area */}
              <div className="p-6 sm:p-10 bg-slate-50/30 dark:bg-slate-900/30">
                <AnimatePresence mode="wait">
                  {activeTab === 'manual' ? (
                    <motion.div
                      key="manual"
                      initial={{ opacity: 0, x: -20 }}
                      animate={{ opacity: 1, x: 0 }}
                      exit={{ opacity: 0, x: 20 }}
                      transition={{ duration: 0.3, ease: [0.22, 1, 0.36, 1] }}
                    >
                      <form onSubmit={handleManualAbsen} className="space-y-5 max-w-md mx-auto">
                        {/* NISN Input */}
                        <div className="space-y-2">
                          <label className="block text-sm font-bold text-slate-700 dark:text-slate-300">
                            Nomor Induk Siswa (NIS/NISN)
                          </label>
                          <div className="relative group">
                            <div className="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                              <Hash className={`transition-colors duration-200 ${errors.nisn ? 'text-red-400' : 'text-slate-400 group-focus-within:text-teal-500'}`} size={20} />
                            </div>
                            <input
                              type="text"
                              name="nisn"
                              value={formData.nisn}
                              onChange={handleInputChange}
                              className={`block w-full pl-12 pr-4 py-4 bg-white dark:bg-slate-800 border-2 rounded-xl text-slate-900 dark:text-white placeholder-slate-400 transition-all duration-200 focus:outline-none ${
                                errors.nisn 
                                  ? 'border-red-300 focus:border-red-500 focus:ring-4 focus:ring-red-500/10' 
                                  : 'border-slate-200 dark:border-slate-700 focus:border-teal-500 focus:ring-4 focus:ring-teal-500/10 hover:border-slate-300 dark:hover:border-slate-600'
                              }`}
                              placeholder="Contoh: 1234567890"
                              disabled={loading}
                            />
                            {errors.nisn && (
                              <motion.p 
                                initial={{ opacity: 0, y: -10 }}
                                animate={{ opacity: 1, y: 0 }}
                                className="mt-2 text-sm text-red-600 dark:text-red-400 flex items-center gap-1.5 font-medium"
                              >
                                <AlertCircle size={14} />
                                {errors.nisn}
                              </motion.p>
                            )}
                          </div>
                        </div>

                        {/* Nama Lengkap Input */}
                        <div className="space-y-2">
                          <label className="block text-sm font-bold text-slate-700 dark:text-slate-300">
                            Nama Lengkap
                          </label>
                          <div className="relative group">
                            <div className="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                              <User className={`transition-colors duration-200 ${errors.nama_lengkap ? 'text-red-400' : 'text-slate-400 group-focus-within:text-teal-500'}`} size={20} />
                            </div>
                            <input
                              type="text"
                              name="nama_lengkap"
                              value={formData.nama_lengkap}
                              onChange={handleInputChange}
                              className={`block w-full pl-12 pr-4 py-4 bg-white dark:bg-slate-800 border-2 rounded-xl text-slate-900 dark:text-white placeholder-slate-400 transition-all duration-200 focus:outline-none ${
                                errors.nama_lengkap 
                                  ? 'border-red-300 focus:border-red-500 focus:ring-4 focus:ring-red-500/10' 
                                  : 'border-slate-200 dark:border-slate-700 focus:border-teal-500 focus:ring-4 focus:ring-teal-500/10 hover:border-slate-300 dark:hover:border-slate-600'
                              }`}
                              placeholder="Masukkan nama lengkap sesuai data sekolah"
                              disabled={loading}
                            />
                            {errors.nama_lengkap && (
                              <motion.p 
                                initial={{ opacity: 0, y: -10 }}
                                animate={{ opacity: 1, y: 0 }}
                                className="mt-2 text-sm text-red-600 dark:text-red-400 flex items-center gap-1.5 font-medium"
                              >
                                <AlertCircle size={14} />
                                {errors.nama_lengkap}
                              </motion.p>
                            )}
                          </div>
                        </div>

                        {/* Info Box */}
                        <div className="bg-amber-50/80 dark:bg-amber-900/20 border border-amber-200/80 dark:border-amber-800/30 rounded-xl p-4 flex items-start gap-3">
                          <div className="p-1.5 bg-amber-100 dark:bg-amber-800/50 rounded-lg flex-shrink-0">
                            <Info className="text-amber-600 dark:text-amber-400" size={18} />
                          </div>
                          <div className="flex-1">
                            <p className="text-sm font-bold text-amber-900 dark:text-amber-200 mb-1">
                              Perhatian
                            </p>
                            <p className="text-xs sm:text-sm text-amber-800 dark:text-amber-300/80 leading-relaxed">
                              Pastikan NISN dan nama lengkap sesuai dengan data sekolah. Jika belum terdaftar, silakan <Link to="/register" className="font-bold underline hover:text-amber-900 dark:hover:text-amber-200 transition-colors">registrasi terlebih dahulu</Link>.
                            </p>
                          </div>
                        </div>

                        {/* Submit Button */}
                        <motion.button
                          whileHover={{ scale: 1.02, y: -2 }}
                          whileTap={{ scale: 0.98 }}
                          type="submit"
                          disabled={loading}
                          className="w-full py-4 bg-gradient-to-r from-slate-900 to-slate-800 dark:from-white dark:to-slate-100 text-white dark:text-slate-900 font-bold rounded-xl shadow-xl shadow-slate-900/20 dark:shadow-white/20 transition-all disabled:opacity-50 disabled:cursor-not-allowed disabled:transform-none flex items-center justify-center gap-3 text-base relative overflow-hidden group"
                        >
                          <div className="absolute inset-0 bg-gradient-to-r from-transparent via-white/10 to-transparent translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-1000" />
                          {loading ? (
                            <>
                              <Loader size={22} className="animate-spin" />
                              <span>Memproses Absensi...</span>
                            </>
                          ) : (
                            <>
                              <CheckCircle size={22} />
                              <span>Absen Sekarang</span>
                            </>
                          )}
                        </motion.button>

                        {/* Register Link */}
                        <p className="text-center text-sm text-slate-500 dark:text-slate-400 pt-2">
                          Belum punya akun?{' '}
                          <Link to="/register" className="font-bold text-teal-600 dark:text-teal-400 hover:text-teal-700 dark:hover:text-teal-300 transition-colors inline-flex items-center gap-1 group">
                            Registrasi di sini
                            <ArrowRight size={14} className="transition-transform group-hover:translate-x-1" />
                          </Link>
                        </p>
                      </form>
                    </motion.div>
                  ) : (
                    <motion.div
                      key="qr"
                      initial={{ opacity: 0, x: 20 }}
                      animate={{ opacity: 1, x: 0 }}
                      exit={{ opacity: 0, x: -20 }}
                      transition={{ duration: 0.3, ease: [0.22, 1, 0.36, 1] }}
                      className="max-w-md mx-auto"
                    >
                      <div className="text-center space-y-6 sm:space-y-8">
                        {/* QR Illustration Area */}
                        <div className="relative">
                          <div className="absolute inset-0 bg-gradient-to-r from-teal-500/10 via-blue-500/10 to-teal-500/10 rounded-3xl blur-2xl animate-pulse" />
                          <div className="relative bg-white dark:bg-slate-800 rounded-2xl p-6 sm:p-8 border-2 border-dashed border-slate-300 dark:border-slate-600 hover:border-teal-400 dark:hover:border-teal-500 transition-all duration-300 group cursor-pointer shadow-sm hover:shadow-md">
                            <motion.div 
                              whileHover={{ scale: 1.05, rotate: 5 }}
                              className="w-20 h-20 sm:w-24 sm:h-24 mx-auto bg-gradient-to-br from-slate-100 to-slate-50 dark:from-slate-700 dark:to-slate-800 rounded-2xl flex items-center justify-center mb-4 shadow-inner group-hover:shadow-lg transition-shadow duration-300"
                            >
                              <QrCode size={40} className="text-slate-400 group-hover:text-teal-500 transition-colors duration-300" />
                            </motion.div>
                            <h3 className="text-lg font-bold text-slate-900 dark:text-white mb-2">
                              Siap Scan
                            </h3>
                            <p className="text-sm text-slate-500 dark:text-slate-400 mb-6 max-w-xs mx-auto leading-relaxed">
                              Klik tombol di bawah untuk mengaktifkan kamera dan arahkan ke QR Code Anda
                            </p>
                            <motion.button
                              whileHover={{ scale: 1.05 }}
                              whileTap={{ scale: 0.95 }}
                              onClick={() => setShowScanner(true)}
                              className="inline-flex items-center gap-2 px-6 sm:px-8 py-3.5 sm:py-4 bg-gradient-to-r from-teal-500 to-teal-600 hover:from-teal-600 hover:to-teal-700 text-white font-bold rounded-xl shadow-lg shadow-teal-500/30 hover:shadow-teal-500/40 transition-all duration-300"
                            >
                              <Camera size={20} />
                              Buka Kamera
                            </motion.button>
                          </div>
                        </div>

                        {/* Tips */}
                        <div className="bg-slate-100/80 dark:bg-slate-800/50 rounded-2xl p-5 sm:p-6 text-left border border-slate-200/50 dark:border-slate-700/50">
                          <h4 className="font-bold text-slate-900 dark:text-white mb-4 flex items-center gap-2 text-sm">
                            <div className="w-6 h-6 rounded-full bg-teal-100 dark:bg-teal-900/50 flex items-center justify-center">
                              <Sparkles size={12} className="text-teal-600 dark:text-teal-400" />
                            </div>
                            Tips Scanning
                          </h4>
                          <ul className="space-y-3 text-sm text-slate-600 dark:text-slate-400">
                            {[
                              'Pastikan pencahayaan cukup terang',
                              'QR Code berada di tengah kamera',
                              'Jangan terlalu dekat atau terlalu jauh'
                            ].map((tip, idx) => (
                              <motion.li 
                                key={idx}
                                initial={{ opacity: 0, x: -10 }}
                                animate={{ opacity: 1, x: 0 }}
                                transition={{ delay: 0.1 * idx }}
                                className="flex items-start gap-3"
                              >
                                <span className="flex-shrink-0 w-5 h-5 rounded-full bg-teal-100 dark:bg-teal-900/30 flex items-center justify-center text-teal-600 dark:text-teal-400 text-xs font-bold">
                                  {idx + 1}
                                </span>
                                <span className="leading-relaxed">{tip}</span>
                              </motion.li>
                            ))}
                          </ul>
                        </div>

                        {/* Register Link */}
                        <p className="text-sm text-slate-500 dark:text-slate-400">
                          Belum punya QR Code?{' '}
                          <Link to="/register" className="font-bold text-teal-600 dark:text-teal-400 hover:text-teal-700 dark:hover:text-teal-300 transition-colors inline-flex items-center gap-1 group">
                            Registrasi dulu
                            <ArrowRight size={14} className="transition-transform group-hover:translate-x-1" />
                          </Link>
                        </p>
                      </div>
                    </motion.div>
                  )}
                </AnimatePresence>

                {/* Result Display */}
                <AnimatePresence>
                  {absenResult && (
                    <motion.div
                      initial={{ opacity: 0, y: 20, scale: 0.95 }}
                      animate={{ opacity: 1, y: 0, scale: 1 }}
                      exit={{ opacity: 0, y: -20, scale: 0.95 }}
                      transition={{ duration: 0.4, ease: [0.22, 1, 0.36, 1] }}
                      className={`mt-8 overflow-hidden rounded-2xl border-2 ${
                        absenResult.success
                          ? 'bg-gradient-to-br from-emerald-50 to-emerald-100/50 dark:from-emerald-900/20 dark:to-emerald-800/10 border-emerald-200 dark:border-emerald-800/50'
                          : 'bg-gradient-to-br from-red-50 to-red-100/50 dark:from-red-900/20 dark:to-red-800/10 border-red-200 dark:border-red-800/50'
                      }`}
                    >
                      <div className="p-5 sm:p-6">
                        <div className="flex items-start gap-4">
                          <div className={`flex-shrink-0 w-12 h-12 rounded-xl flex items-center justify-center shadow-lg ${
                            absenResult.success 
                              ? 'bg-gradient-to-br from-emerald-500 to-emerald-600 text-white shadow-emerald-500/30' 
                              : 'bg-gradient-to-br from-red-500 to-red-600 text-white shadow-red-500/30'
                          }`}>
                            {absenResult.success ? <CheckCircle size={24} /> : <X size={24} />}
                          </div>
                          
                          <div className="flex-1 min-w-0">
                            <h4 className={`font-bold text-lg mb-1 ${
                              absenResult.success 
                                ? 'text-emerald-900 dark:text-emerald-100' 
                                : 'text-red-900 dark:text-red-100'
                            }`}>
                              {absenResult.success ? 'Absensi Berhasil!' : 'Absensi Gagal'}
                            </h4>
                            <p className={`text-sm mb-4 ${
                              absenResult.success 
                                ? 'text-emerald-700 dark:text-emerald-300' 
                                : 'text-red-700 dark:text-red-300'
                            }`}>
                              {absenResult.message}
                            </p>
                            
                            {absenResult.success && absenResult.data && (
                              <div className="bg-white/70 dark:bg-slate-900/50 rounded-xl p-4 space-y-3 border border-white/50 dark:border-slate-700/50 backdrop-blur-sm">
                                <div className="grid grid-cols-2 gap-4 text-sm">
                                  <div className="space-y-1">
                                    <p className="text-slate-500 dark:text-slate-400 text-[10px] uppercase tracking-wider font-bold">Nama</p>
                                    <p className="font-bold text-slate-900 dark:text-white truncate">{absenResult.data.siswa?.nama}</p>
                                  </div>
                                  <div className="space-y-1">
                                    <p className="text-slate-500 dark:text-slate-400 text-[10px] uppercase tracking-wider font-bold">Kelas</p>
                                    <p className="font-bold text-slate-900 dark:text-white">{absenResult.data.siswa?.kelas}</p>
                                  </div>
                                  <div className="space-y-1">
                                    <p className="text-slate-500 dark:text-slate-400 text-[10px] uppercase tracking-wider font-bold">Status</p>
                                    <span className={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-bold ${
                                      absenResult.data.is_terlambat 
                                        ? 'bg-amber-100 text-amber-800 dark:bg-amber-900/50 dark:text-amber-300' 
                                        : 'bg-emerald-100 text-emerald-800 dark:bg-emerald-900/50 dark:text-emerald-300'
                                    }`}>
                                      <span className={`w-1.5 h-1.5 rounded-full ${absenResult.data.is_terlambat ? 'bg-amber-500' : 'bg-emerald-500'}`} />
                                      {absenResult.data.is_terlambat ? 'Terlambat' : 'Tepat Waktu'}
                                    </span>
                                  </div>
                                  {absenResult.data.menit_terlambat > 0 && (
                                    <div className="space-y-1">
                                      <p className="text-slate-500 dark:text-slate-400 text-[10px] uppercase tracking-wider font-bold">Keterlambatan</p>
                                      <p className="font-bold text-amber-700 dark:text-amber-400">{absenResult.data.menit_terlambat} menit</p>
                                    </div>
                                  )}
                                </div>
                                
                                {absenResult.data.absensi && (
                                  <div className="pt-3 mt-3 border-t border-slate-200/60 dark:border-slate-700/60">
                                    <div className="flex items-center justify-between text-xs">
                                      <span className="text-slate-500 dark:text-slate-400 font-medium flex items-center gap-1.5">
                                        <Clock size={12} />
                                        {absenResult.data.absensi.tanggal} • {absenResult.data.absensi.jam_masuk}
                                      </span>
                                      <button
                                        onClick={() => debugAbsensi(absenResult.data.siswa.id)}
                                        className="text-[10px] font-medium text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 transition-colors flex items-center gap-1"
                                      >
                                        <Shield size={10} />
                                        Debug
                                      </button>
                                    </div>
                                  </div>
                                )}
                              </div>
                            )}
                          </div>
                        </div>
                      </div>
                      
                      {/* Progress Bar for Success */}
                      {absenResult.success && (
                        <motion.div 
                          initial={{ scaleX: 0 }}
                          animate={{ scaleX: 1 }}
                          transition={{ duration: 2.5, ease: "easeOut" }}
                          className="h-1 bg-gradient-to-r from-emerald-500 to-emerald-400 origin-left"
                        />
                      )}
                    </motion.div>
                  )}
                </AnimatePresence>
              </div>
            </div>

            {/* Bottom Info */}
            <motion.div 
              initial={{ opacity: 0 }}
              animate={{ opacity: 1 }}
              transition={{ delay: 0.8 }}
              className="mt-8 text-center"
            >
              <div className="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/50 dark:bg-slate-800/50 border border-slate-200/50 dark:border-slate-700/50 backdrop-blur-sm">
                <Shield size={14} className="text-slate-400" />
                <p className="text-xs text-slate-500 dark:text-slate-400 font-medium">
                  © {new Date().getFullYear()} {pengaturan.nama_sekolah || 'SMK Negeri 8 Jember'}. Sistem Absensi Digital Terintegrasi.
                </p>
              </div>
            </motion.div>
          </motion.div>
        </div>
      </main>

      {/* QR Scanner Modal */}
      {showScanner && (
        <QrScanner
          onScan={handleQrScan}
          onError={handleScanError}
          onClose={() => setShowScanner(false)}
        />
      )}
    </div>
  )
}